#metadata(
    identifier: 12345,
    title: "Les Ailéris : Anya",
    language: fr
)

#manifest.add(
    id: "cover-img",
    href: "cover.jpg",
    mediaType: "image/jpeg",
    properties: "cover-image",
    source: "epub/cover.jpg"
)

#manifest.add(
    id: "le-prologue",
    href: "prologue.xhtml",
    mediaType: "application/xhtml+xml",
    spine: true,
    nav: "Prologue",
)[
<head>
    <title>Chapitre 1</title>
</head>
<body>
    <h1>Hello Chapitre 1</h1>
    <p>La nav doit indiquer "Prologue" et pas "le-prologue"</p>
</body>
]

#manifest.add(
    id: "chap1",
    href: "chapitre1.xhtml",
    mediaType: "application/xhtml+xml",
    spine: true,
)[
<head>
    <title>Chapitre 1</title>
